{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "regions": ["icn1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "dev": true
    }
  },
  "env": [
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "value": "@site-url"
    }
  ],
  "envs": {
    "NEXT_PUBLIC_SITE_URL": {
      "production": "https://oddkit.tools",
      "preview": "https://$VERCEL_URL"
    }
  }
}
